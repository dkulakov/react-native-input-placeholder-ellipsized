{
  "name": "react-native-input-placeholder-ellipsized",
  "version": "0.2.0",
  "description": "React Native module to fix TextInput placeholder ellipsize on Android",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "src",
    "lib",
    "android",
    "plugin",
    "!android/build",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "prepare": "bob build",
    "typescript": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "android",
    "textinput",
    "ellipsize",
    "placeholder",
    "expo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dkulakov/react-native-input-placeholder-ellipsized.git"
  },
  "author": "dkulakov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dkulakov/react-native-input-placeholder-ellipsized/issues"
  },
  "homepage": "https://github.com/dkulakov/react-native-input-placeholder-ellipsized#readme",
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.72.0",
    "react-native-builder-bob": "^0.20.0",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "expo": {
    "name": "react-native-input-placeholder-ellipsized",
    "version": "0.2.0",
    "platforms": [
      "android"
    ]
  },
  "exportedModules": {
    "plugin": "plugin"
  }
}
